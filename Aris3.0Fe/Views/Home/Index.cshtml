@model List<Film>

@{
    ViewData["Title"] = "Home Page";
}

<div class="media-title">
    <label class="film-name" id="film-name"></label>
    <div class="content" id="film-content"></div>
        @* <button class="btn-love ms-3">
            <i class="bi bi-suit-heart-fill"></i>
        </button> *@
</div>
<div class="btn-group">
    <a id ="play-button" asp-controller="Film" asp-action="Index" class="btn btn-play">
        <i class="bi bi-play-fill"></i>
    </a>
</div>


<script>
    const films = @Html.Raw(Json.Serialize(Model));
    let index = 0;

    function showFilm(i) {
        if (!films[i]) return;
        document.getElementById('film-name').textContent = films[i].name;
        document.getElementById('film-content').textContent = films[i].content;
        const playButton = document.getElementById('play-button');
        playButton.href = '@Url.Action("Index", "Film")?id=' + encodeURIComponent(films[i].id);
    }

    showFilm(index);

    setInterval(() => {
        index = (index + 1) % films.length;
        showFilm(index);
    }, 600000); 
</script>
